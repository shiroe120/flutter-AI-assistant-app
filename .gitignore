# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Ignore C++ source and header files in platform folders
desktop_platforms = ["windows", "linux", "macos"]
for platform in desktop_platforms:
    print(f"**/{platform}/**/*.cpp\n**/{platform}/**/*.cc\n**/{platform}/**/*.cxx\n**/{platform}/**/*.c\n**/{platform}/**/*.h\n**/{platform}/**/*.hpp\n**/{platform}/**/*.hxx\n**/{platform}/**/*.hh\n**/{platform}/**/*.inl\n**/{platform}/**/*.ipp\n**/{platform}/**/*.tcc\n**/{platform}/**/*.tpp\n")

# Add ignore rules for C++ files in platform folders
**/windows/**/*.cpp
**/windows/**/*.cc
**/windows/**/*.cxx
**/windows/**/*.c
**/windows/**/*.h
**/windows/**/*.hpp
**/windows/**/*.hxx
**/windows/**/*.hh
**/windows/**/*.inl
**/windows/**/*.ipp
**/windows/**/*.tcc
**/windows/**/*.tpp
**/linux/**/*.cpp
**/linux/**/*.cc
**/linux/**/*.cxx
**/linux/**/*.c
**/linux/**/*.h
**/linux/**/*.hpp
**/linux/**/*.hxx
**/linux/**/*.hh
**/linux/**/*.inl
**/linux/**/*.ipp
**/linux/**/*.tcc
**/linux/**/*.tpp
**/macos/**/*.cpp
**/macos/**/*.cc
**/macos/**/*.cxx
**/macos/**/*.c
**/macos/**/*.h
**/macos/**/*.hpp
**/macos/**/*.hxx
**/macos/**/*.hh
**/macos/**/*.inl
**/macos/**/*.ipp
**/macos/**/*.tcc
**/macos/**/*.tpp

.env
